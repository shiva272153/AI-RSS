# ============================================
#  Backend Environment Variables
#  Copy this file to .env and fill in values
#  ⚠️ NEVER commit your actual .env file!
# ============================================

PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-resume-screening
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
ML_ENGINE_URL=http://localhost:5001

# Email Configuration (Gmail SMTP)
# To use Gmail: enable 2FA on your Google account,
# then generate an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=AI Resume Screening <your-email@gmail.com>
